datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

model User {
  id                     String     @id @default(cuid())
  name                   String?    @unique @db.VarChar(32)
  email                  String?    @unique
  emailVerified          DateTime?  @map("email_verified")
  passwordHash           String?
  image                  String?
  background             String?
  bio                    String?
  profileColor           String?
  accentColor            String?
  privacy                String     @default("public")
  libraryPrivacy         String     @default("public")
  logsPrivacy            String     @default("public")
  activityPrivacy        String     @default("public")
  playlistPrivacy        String     @default("public")
  contactEmail           String?
  website                String?
  socials                String?    @db.Text
  preferences            String?    @db.Text
  widgets                String?    @db.Text
  commentsHidden         Boolean    @default(false)
  hideCommentsEverywhere Boolean    @default(false)
  defaultGameListStatus  String     @default("all")
  defaultGameListSort    String     @default("added")
  defaultGameListView    String     @default("grid")
  defaultActivityFilter  String     @default("all")
  siteThemeMode          String     @default("default")
  siteThemeColor         String?
  siteAccentColor        String?
  notifyCommentReplies   Boolean    @default(true)
  notifyProfileComments  Boolean    @default(true)
  notifyLikes            Boolean    @default(true)
  notifyFollows          Boolean    @default(true)
  notifyFollowerLists    Boolean    @default(true)
  notifyBadges           Boolean    @default(true)
  roles                  UserRole[] @default([])
  accounts               Account[]
  sessions               Session[]

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  games             UserGameEntry[]
  tags              UserTag[]
  gameLists         GameList[]
  likes             Like[]
  comments          Comment[]
  activities        Activity[]
  notifications     Notification[]
  sentNotifications Notification[]    @relation("NotificationActor")
  following         UserFollow[]      @relation("UserFollowing")
  followers         UserFollow[]      @relation("UserFollowers")
  badges            UserBadge[]
  userGamePlayLogs  UserGamePlayLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Game {
  id           Int       @id
  slug         String    @unique
  name         String
  summary      String?
  totalRating  Float?
  releaseDate  DateTime?
  cover        String?
  screenshots  String[]
  videos       String[]
  developers   Int[]
  publishers   Int[]
  platforms    Int[]
  genres       Int[]
  franchises   Int[]
  collections  Int[]
  similarGames Int[]
  keywords     Int[]     @default([])
  gameType     GameType  @default(MAINGAME)

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  users            UserGameEntry[]
  listEntries      GameListEntry[]
  activities       Activity[]
  userGamePlayLogs UserGamePlayLog[]

  @@index([name])
  @@index([gameType])
  @@index([keywords], type: Gin, map: "Game_keywords_gin_idx")
}

model UserGameEntry {
  id           String     @id @default(cuid())
  userId       String
  gameId       Int
  status       GameStatus @default(BACKLOG)
  rating       Float?
  timePlayed   Float?
  timeMode     String     @default("logs")
  timeFinished Float?
  timeMastered Float?
  notes        String?    @db.Text
  favorite     Boolean    @default(false)
  addedAt      DateTime   @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
  masteredAt   DateTime?
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  game         Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  userGamePlayLogs  UserGamePlayLog[]
  userGameEntryTags UserGameEntryTag[]

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
  @@index([userId, status])
}

model UserTag {
  id         String             @id @default(cuid())
  userId     String
  name       String             @db.VarChar(40)
  normalized String             @db.VarChar(40)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries    UserGameEntryTag[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([userId, normalized])
  @@index([userId])
}

model UserGameEntryTag {
  entryId String
  tagId   String
  entry   UserGameEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag     UserTag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([entryId, tagId])
  @@index([tagId])
}

model UserGamePlayLog {
  id        String   @id @default(cuid())
  userId    String
  entryId   String
  gameId    Int
  hours     Float
  note      String   @db.Text
  skipRecap Boolean  @default(false)
  playedAt  DateTime @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameEntry UserGameEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, playedAt])
  @@index([userId, gameId])
}

model GameList {
  id             String          @id @default(cuid())
  userId         String
  type           GameListType
  displayMode    String          @default("GRID")
  tierLabels     String[]        @default(["S", "A", "B", "C", "D"])
  tierColors     String[]        @default(["#f59e0b", "#22c55e", "#3b82f6", "#a855f7", "#ef4444"])
  name           String
  slug           String?
  description    String?         @db.Text
  image          String?
  background     String?
  color          String?
  accentColor    String?
  privacy        String          @default("public")
  commentsHidden Boolean         @default(false)
  entries        GameListEntry[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@index([userId])
  @@index([userId, type])
}

model GameListEntry {
  id       String   @id @default(cuid())
  listId   String
  gameId   Int
  position Int?
  tier     String?
  addedAt  DateTime @default(now())
  list     GameList @relation(fields: [listId], references: [id], onDelete: Cascade)
  game     Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([listId, gameId])
  @@index([listId])
  @@index([gameId])
}

model Collection {
  id    Int    @id
  slug  String @unique
  name  String
  games Int[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Franchise {
  id    Int    @id
  slug  String @unique
  name  String
  games Int[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Genre {
  id   Int    @id
  slug String @unique
  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Platform {
  id   Int    @id
  slug String @unique
  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id          Int     @id
  slug        String  @unique
  name        String?
  logo        String?
  description String?
  developed   Int[]
  published   Int[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Keyword {
  id   Int    @id
  slug String @unique
  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Activity {
  id String @id @default(cuid())

  userId String
  type   ActivityType

  targetType InteractionTargetType?
  targetId   String?
  gameId     Int?
  listId     String?
  commentId  String?

  message String? @db.Text

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game    Game?    @relation(fields: [gameId], references: [id], onDelete: SetNull)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  expiresAt DateTime @default(dbgenerated("(CURRENT_TIMESTAMP + INTERVAL '30 days')"))

  @@index([userId])
  @@index([type])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([expiresAt])
}

model Like {
  id String @id @default(cuid())

  userId     String
  targetType LikeTargetType
  targetId   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([userId])
}

model Comment {
  id String @id @default(cuid())

  userId     String
  targetType InteractionTargetType
  targetId   String
  parentId   String?
  content    String                @db.Text

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent        Comment?       @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]      @relation("CommentReplies")
  activities    Activity[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([parentId])
  @@index([userId])
}

model UserFollow {
  id String @id @default(cuid())

  followerId  String
  followingId String

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Badge {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String? @db.Text
  icon        String?
  color       String?

  users UserBadge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserBadge {
  id String @id @default(cuid())

  userId  String
  badgeId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

model Notification {
  id String @id @default(cuid())

  userId  String
  actorId String?
  type    NotificationType

  targetType InteractionTargetType?
  targetId   String?
  commentId  String?
  message    String?                @db.Text
  readAt     DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor   User?    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

enum GameListType {
  LIBRARY
  PLAYLIST
}

enum GameStatus {
  BACKLOG
  PLAYING
  COMPLETED
  DROPPED
  PAUSED
  WISHLIST
}

enum GameType {
  MAINGAME
  DLC
  EXPANSION
  BUNDLE
  STANDALONE_EXPANSION
  MOD
  EPISODE
  SEASON
  REMAKE
  REMASTER
  EXPANDED_GAME
  PORT
  FORK
  PACK
  UPDATE
}

enum ActivityType {
  ADDED_GAME_TO_LIBRARY
  RATED_GAME
  LOGGED_GAME_PLAY
  CREATED_PLAYLIST
  ADDED_GAME_TO_PLAYLIST
  LIKED_GAME_LIST
  LIKED_COMMENT
  COMMENTED_ON_GAME_LIST
  COMMENTED_ON_PROFILE
  COMMENTED_ON_GAME
  REPLIED_TO_COMMENT
  FOLLOWED_USER
  EARNED_BADGE
}

enum InteractionTargetType {
  GAME_LIST
  USER_PROFILE
  GAME
}

enum LikeTargetType {
  GAME_LIST
  COMMENT
}

enum NotificationType {
  COMMENT_REPLY
  COMMENTED_ON_PROFILE
  RECEIVED_LIKE
  FOLLOWED_USER
  FOLLOWING_CREATED_LIST
  EARNED_BADGE
}

enum UserRole {
  ADMIN
  STAFF
  VIP
}
