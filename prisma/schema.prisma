datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  passwordHash  String?
  image         String?
  background    String?
  bio           String?
  profileColor  String?
  accentColor   String?
  privacy       String    @default("public")
  contactEmail  String?
  website       String?
  socials       String?   @db.Text
  preferences   String?   @db.Text
  widgets       String?   @db.Text
  accounts      Account[]
  sessions      Session[]

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  games     UserGameEntry[]
  gameLists GameList[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Game {
  id           Int       @id
  slug         String    @unique
  name         String
  summary      String?
  totalRating  Float?
  releaseDate  DateTime?
  cover        String?
  screenshots  String[]
  videos       String[]
  developers   Int[]
  publishers   Int[]
  platforms    Int[]
  genres       Int[]
  franchises   Int[]
  collections  Int[]
  similarGames Int[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  users       UserGameEntry[]
  listEntries GameListEntry[]
}

model UserGameEntry {
  id         String     @id @default(cuid())
  userId     String
  gameId     Int
  status     GameStatus @default(BACKLOG)
  rating     Int?
  progress   Int?
  notes      String?    @db.Text
  favorite   Boolean    @default(false)
  addedAt    DateTime   @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  game       Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
  @@index([userId, status])
}

model GameList {
  id          String          @id @default(cuid())
  userId      String
  type        GameListType
  name        String
  slug        String?
  description String?         @db.Text
  image       String?
  background  String?
  color       String?
  accentColor String?
  privacy     String          @default("public")
  entries     GameListEntry[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@index([userId])
  @@index([userId, type])
}

model GameListEntry {
  id       String   @id @default(cuid())
  listId   String
  gameId   Int
  position Int?
  addedAt  DateTime @default(now())
  list     GameList @relation(fields: [listId], references: [id], onDelete: Cascade)
  game     Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([listId, gameId])
  @@index([listId])
  @@index([gameId])
}

model Collection {
  id    Int    @id
  slug  String @unique
  name  String
  games Int[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Franchise {
  id    Int    @id
  slug  String @unique
  name  String
  games Int[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Genre {
  id   Int    @id
  slug String @unique
  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Platform {
  id   Int    @id
  slug String @unique
  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id          Int     @id
  slug        String  @unique
  name        String?
  logo        String?
  description String?
  developed   Int[]
  published   Int[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GameListType {
  LIBRARY
  PLAYLIST
}

enum GameStatus {
  BACKLOG
  PLAYING
  COMPLETED
  DROPPED
  PAUSED
  WISHLIST
}
