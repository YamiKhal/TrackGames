{
	"name": "trackgames",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev",
		"dev:webpack": "next dev --webpack",
		"build": "prisma generate && next build",
		"start": "next start",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier . --write",
		"format:check": "prettier . --check",
		"fix": "npm run lint:fix && npm run format",
		"tc": "tsc --noEmit",
		"check": "npm run tc && npm run lint && npm run format:check",
		"check:all": "npm run tc; npm run lint; npm run format:check",
		"import:api": "tsx scripts/import-api.ts",
		"import:clear-data": "tsx scripts/clear-import-data.ts",
		"webhooks:register": "tsx scripts/register-webhooks.ts"
	},
	"engines": {
		"node": "22.13.x"
	},
	"dependencies": {
		"@auth/prisma-adapter": "^2.11.2",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@thesvg/react": "^3.0.10",
		"eslint-plugin-import": "^2.32.0",
		"lucide-react": "^1.16.0",
		"next": "16.2.6",
		"next-auth": "^5.0.0-beta.31",
		"prisma": "^7.8.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-markdown": "^10.1.0",
		"rehype-sanitize": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"tsx": "^4.22.4",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"eslint": "^9",
		"eslint-config-next": "16.2.6",
		"eslint-config-prettier": "^10.1.8",
		"prettier": "^3.9.3",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"tailwindcss": "^4",
		"typescript": "^5"
	}
}
