{
	"name": "trackgames",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev",
		"dev:webpack": "next dev --webpack",
		"build": "prisma generate && next build",
		"start": "next start",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier . --write",
		"format:check": "prettier . --check",
		"fix": "npm run lint:fix && npm run format",
		"tc": "tsc --noEmit",
		"check": "npm run tc && npm run lint && npm run format:check",
		"check:all": "npm run tc; npm run lint; npm run format:check",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"test:e2e": "playwright test",
		"import:api": "tsx scripts/import-api.ts",
		"import:clear-data": "tsx scripts/clear-import-data.ts",
		"webhooks:register": "tsx scripts/register-webhooks.ts",
		"prepare": "husky"
	},
	"engines": {
		"node": "22.13.x"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": "eslint --fix",
		"*.{js,jsx,ts,tsx,json,css,md}": "prettier --write"
	},
	"dependencies": {
		"@auth/prisma-adapter": "^2.11.2",
		"@google-analytics/data": "^6.1.0",
		"@next/third-parties": "^16.2.10",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@thesvg/react": "^3.0.10",
		"eslint-plugin-import": "^2.32.0",
		"ioredis": "^5.11.1",
		"lucide-react": "^1.16.0",
		"next": "16.2.6",
		"next-auth": "^5.0.0-beta.31",
		"prisma": "^7.8.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-markdown": "^10.1.0",
		"rehype-sanitize": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"tailwind-merge": "^3.6.0",
		"tsx": "^4.22.4",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@tailwindcss/postcss": "^4",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"dotenv": "^17.4.2",
		"eslint": "^9",
		"eslint-config-next": "16.2.6",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"husky": "^9.1.7",
		"jest": "^30.4.2",
		"jest-environment-jsdom": "^30.4.1",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.8",
		"prettier": "^3.9.3",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"tailwindcss": "^4",
		"ts-node": "^10.9.2",
		"typescript": "^5"
	}
}
